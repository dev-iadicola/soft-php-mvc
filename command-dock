#!/bin/bash

###############################################
# Dock - Docker wrapper for SoftCLI
# Usage: ./dock <command> [options]
#
# Examples:
#   ./dock soft migrate
#   ./dock soft seed --fresh
#   ./dock composer install
#   ./dock php -v
#   ./dock shell
#   ./dock up / down / restart / logs
###############################################

SERVICE="app"
CONTAINER_NAME="soft-php-mvc"
DOCKER_COMPOSE="docker compose"

# Colors
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
NC='\033[0m'

# Check if docker is running
if ! docker info > /dev/null 2>&1; then
    echo -e "${RED}Error: Docker is not running.${NC}"
    exit 1
fi

# Check if container is running
container_running() {
    docker ps --format '{{.Names}}' | grep -q "^${CONTAINER_NAME}$"
}

ensure_container() {
    if ! container_running; then
        echo -e "${YELLOW}Container '${CONTAINER_NAME}' is not running. Starting...${NC}"
        $DOCKER_COMPOSE up -d
        sleep 2
        if ! container_running; then
            echo -e "${RED}Error: Failed to start container.${NC}"
            exit 1
        fi
        echo -e "${GREEN}Container started.${NC}"
    fi
}

# Determine TTY flags
if [ -t 0 ]; then
    EXEC_FLAGS="-it"
else
    EXEC_FLAGS="-i"
fi

case "$1" in
    # Docker Compose commands
    up)
        shift
        $DOCKER_COMPOSE up -d "$@"
        ;;
    down)
        shift
        $DOCKER_COMPOSE down "$@"
        ;;
    restart)
        shift
        $DOCKER_COMPOSE restart "$@"
        ;;
    build)
        shift
        $DOCKER_COMPOSE build "$@"
        ;;
    logs)
        shift
        $DOCKER_COMPOSE logs -f "$@"
        ;;

    # Open a shell in the container
    shell|bash)
        ensure_container
        docker exec $EXEC_FLAGS "$CONTAINER_NAME" bash
        ;;

    # Run SoftCLI commands (php soft ...)
    soft)
        ensure_container
        shift
        docker exec $EXEC_FLAGS "$CONTAINER_NAME" php soft "$@"
        ;;

    # Run raw PHP
    php)
        ensure_container
        shift
        docker exec $EXEC_FLAGS "$CONTAINER_NAME" php "$@"
        ;;

    # Composer
    composer)
        ensure_container
        shift
        docker exec $EXEC_FLAGS "$CONTAINER_NAME" composer "$@"
        ;;

    # PHPUnit
    test)
        ensure_container
        shift
        docker exec $EXEC_FLAGS "$CONTAINER_NAME" vendor/bin/phpunit "$@"
        ;;

    # Rector
    rector)
        ensure_container
        shift
        docker exec $EXEC_FLAGS "$CONTAINER_NAME" vendor/bin/rector "$@"
        ;;

    # MySQL CLI
    mysql)
        ensure_container
        shift
        docker exec $EXEC_FLAGS soft-php-mvc-db mysql -uroot -p"${DB_PSW:-secret}" "${DB_NAME:-soft_mvc}" "$@"
        ;;

    # Help
    help|-h|--help)
        echo -e "${GREEN}Dock${NC} - Docker wrapper for SoftCLI"
        echo ""
        echo "Usage: ./dock <command> [options]"
        echo ""
        echo -e "${YELLOW}Docker commands:${NC}"
        echo "  up              Start containers"
        echo "  down            Stop containers"
        echo "  restart         Restart containers"
        echo "  build           Build containers"
        echo "  logs            View container logs"
        echo ""
        echo -e "${YELLOW}Application commands:${NC}"
        echo "  soft <cmd>      Run SoftCLI (e.g. ./dock soft migrate)"
        echo "  php <args>      Run PHP command"
        echo "  composer <cmd>  Run Composer command"
        echo "  test [args]     Run PHPUnit tests"
        echo "  rector [args]   Run Rector"
        echo "  shell           Open bash shell in container"
        echo "  mysql           Open MySQL CLI"
        echo ""
        echo -e "${YELLOW}Examples:${NC}"
        echo "  ./dock up                    Start the environment"
        echo "  ./dock soft migrate          Run migrations"
        echo "  ./dock soft seed --fresh     Run seeders"
        echo "  ./dock soft make:model Post  Create a new model"
        echo "  ./dock composer require x/y  Install a package"
        echo "  ./dock test                  Run tests"
        ;;

    # No args: open shell (backward compatible)
    "")
        ensure_container
        docker exec $EXEC_FLAGS "$CONTAINER_NAME" bash
        ;;

    # Fallback: run any command inside the container
    *)
        ensure_container
        docker exec $EXEC_FLAGS "$CONTAINER_NAME" "$@"
        ;;
esac
